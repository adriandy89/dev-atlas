---
import { t } from '../ui';
import Icon from './Icon.astro';

interface Enlace {
  href: string;
  title: string;
}

interface Props {
  anterior?: Enlace;
  siguiente?: Enlace;
}

const { anterior, siguiente } = Astro.props;
---

{
  (anterior || siguiente) && (
    <nav class="prevnext" aria-label="Navegación entre temas">
      {anterior ? (
        <a class="pn glass" href={anterior.href} rel="prev">
          <span class="pn-label">
            <span class="flip">
              <Icon name="flecha" size={14} />
            </span>
            {t.labels.anterior}
          </span>
          <span class="pn-title">{anterior.title}</span>
        </a>
      ) : (
        <span />
      )}
      {siguiente && (
        <a class="pn glass pn-next" href={siguiente.href} rel="next">
          <span class="pn-label">
            {t.labels.siguiente}
            <Icon name="flecha" size={14} />
          </span>
          <span class="pn-title">{siguiente.title}</span>
        </a>
      )}
    </nav>
  )
}

<style>
  /* Se alinea con el ancho de lectura de .prose para no estirarse de más
     en la columna de artículo (más ancha que el texto en escritorio). */
  .prevnext {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-top: 3rem;
    max-width: var(--container-prose);
  }

  @media (min-width: 680px) {
    .prevnext {
      grid-template-columns: 1fr 1fr;
    }
  }

  .pn {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 0.95rem;
    border-radius: var(--radius);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  @media (hover: hover) {
    .pn:hover {
      border-color: var(--border-strong);
      transform: translateY(-2px);
    }
  }

  .pn-next {
    text-align: right;
    align-items: flex-end;
  }

  .pn-label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cyan);
  }

  .flip {
    display: inline-flex;
    transform: scaleX(-1);
  }

  .pn-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1.3;
    color: var(--text);
  }
</style>

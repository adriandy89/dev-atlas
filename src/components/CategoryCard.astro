---
import type { Categoria } from '../lib/categorias';
import Icon from './Icon.astro';
import ProgressBar from './ProgressBar.astro';

interface Props {
  categoria: Categoria;
  /** Texto del pie (p. ej. "3 temas" o "Próximamente") */
  meta?: string;
  /** Destino (por defecto, la categoría en Temas) */
  href?: string;
  /** Atenuada (categoría aún sin contenido) */
  muted?: boolean;
  /** Muestra la barra de progreso de temas leídos (hidratada en cliente) */
  showProgress?: boolean;
  /** Total de temas de la categoría (denominador de la barra) */
  total?: number;
}

const {
  categoria,
  meta,
  href = `/temas/${categoria.slug}/`,
  muted = false,
  showProgress = false,
  total = 0,
} = Astro.props;
---

<a
  class:list={[
    'card glass glass-aurora glass-aurora-hover cat-card',
    `cat-${categoria.color}`,
    muted && 'is-muted',
  ]}
  href={href}
>
  <span class="cat-icon"><Icon name={categoria.icon} size={22} /></span>
  <h3>{categoria.name}</h3>
  <p class="card-desc">{categoria.description}</p>
  {meta && <p class="card-meta">{meta}</p>}
  {
    showProgress && total > 0 && (
      <div class="cat-progreso" data-cat-slug={categoria.slug} data-total={total} hidden>
        <ProgressBar label={`Progreso en ${categoria.name}`} />
        <span class="cat-progreso-texto" data-cat-conteo />
      </div>
    )
  }
</a>

<style>
  .cat-icon {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .cat-cyan .cat-icon {
    color: var(--cyan);
    background: var(--accent-soft);
  }

  .cat-violet .cat-icon {
    color: var(--violet);
    background: var(--violet-soft);
  }

  .is-muted {
    opacity: 0.65;
  }

  .is-muted .card-meta {
    color: var(--violet);
  }

  .cat-progreso {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .cat-progreso-texto {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    color: var(--cyan);
  }
</style>

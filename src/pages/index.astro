---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import HeroScene from '../components/HeroScene.astro';
import CategoryCard from '../components/CategoryCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { SITE } from '../config';
import { listaCategorias, CATEGORIAS } from '../lib/categorias';
import { getTemas, getProblemas, getPreguntas, conteosPorCategoria } from '../lib/content';
import { t } from '../ui';

const [temas, problemas, preguntas, conteos] = await Promise.all([
  getTemas(),
  getProblemas(),
  getPreguntas(),
  conteosPorCategoria(),
]);

const ultimos = [...temas]
  .sort((a, b) => b.data.updated.getTime() - a.data.updated.getTime())
  .slice(0, 3);

const stats = [
  { valor: temas.length, etiqueta: 'temas' },
  { valor: problemas.length, etiqueta: 'problemas' },
  { valor: preguntas.length, etiqueta: 'preguntas' },
  { valor: listaCategorias.length, etiqueta: 'categorías' },
];

const secciones = [
  {
    href: '/temas/',
    icon: 'libro',
    titulo: 'Temas',
    desc: 'La teoría que no caduca, explicada con código y con las trampas señaladas.',
    meta: t.labels.temasCount(temas.length),
  },
  {
    href: '/problemas/',
    icon: 'objetivo',
    titulo: 'Problemas',
    desc: 'Enunciados con ejemplos, pistas progresivas y solución razonada con complejidad.',
    meta: t.labels.problemasCount(problemas.length),
  },
  {
    href: '/quiz/',
    icon: 'quiz',
    titulo: 'Quiz',
    desc: 'Preguntas de opción múltiple con explicación en cada respuesta. Tu progreso se guarda.',
    meta: t.labels.preguntasCount(preguntas.length),
  },
];

const destacadas = listaCategorias.filter((c) => (conteos.temas[c.slug] ?? 0) > 0);
---

<Layout
  title={`${SITE.name} — Conocimiento de ingeniería de software`}
  description={SITE.description}
>
  <section class="hero container">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-copy">
      <p class="hero-badge reveal">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        Atlas de ingeniería de software
      </p>
      <h1 class="reveal" style="--reveal-delay: 0.06s">
        Domina los fundamentos.<br />
        <span class="text-aurora hero-shimmer">Construye mejor software.</span>
      </h1>
      <p class="hero-sub reveal" style="--reveal-delay: 0.12s">
        Temas explicados con claridad, problemas resueltos paso a paso y quiz para poner a prueba lo
        que sabes. En español y sin ruido.
      </p>
      <div class="hero-cta reveal" style="--reveal-delay: 0.18s">
        <a class="btn btn-primary" href="/temas/">Explorar temas <Icon name="flecha" size={18} /></a>
        <a class="btn btn-ghost" href="/quiz/">Ponte a prueba</a>
      </div>
    </div>
    <div class="hero-visual reveal" style="--reveal-delay: 0.2s">
      <HeroScene />
    </div>
    <dl class="stats glass reveal" style="--reveal-delay: 0.24s">
      {
        stats.map((stat) => (
          <div class="stat">
            <dt class="visually-hidden">{stat.etiqueta}</dt>
            <dd>
              <span class="stat-num text-aurora" data-count={stat.valor}>
                {stat.valor}
              </span>
              <span class="stat-label">{stat.etiqueta}</span>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section class="section container" aria-labelledby="titulo-secciones">
    <div class="section-head">
      <p class="eyebrow">Tres formas de aprender</p>
      <h2 id="titulo-secciones">Leer, practicar, comprobar</h2>
    </div>
    <div class="card-grid">
      {
        secciones.map((seccion, i) => (
          <a
            class="card glass glass-aurora glass-aurora-hover seccion reveal"
            style={`--reveal-delay: ${i * 0.08}s`}
            href={seccion.href}
          >
            <span class="seccion-icon">
              <Icon name={seccion.icon} size={24} />
            </span>
            <h3>{seccion.titulo}</h3>
            <p class="card-desc">{seccion.desc}</p>
            <p class="card-meta">
              {seccion.meta}
              <Icon name="flecha" size={14} />
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section container" aria-labelledby="titulo-categorias">
    <div class="section-head head-row">
      <div>
        <p class="eyebrow">Explora por área</p>
        <h2 id="titulo-categorias">Categorías</h2>
      </div>
      <a class="btn btn-ghost btn-sm" href="/temas/">{t.labels.verTodo}</a>
    </div>
    <div class="card-grid">
      {
        destacadas.map((cat, i) => (
          <div class="reveal" style={`--reveal-delay: ${(i % 3) * 0.07}s`}>
            <CategoryCard categoria={cat} meta={t.labels.temasCount(conteos.temas[cat.slug] ?? 0)} />
          </div>
        ))
      }
    </div>
  </section>

  {
    ultimos.length > 0 && (
      <section class="section container" aria-labelledby="titulo-ultimos">
        <div class="section-head head-row">
          <div>
            <p class="eyebrow">Recién actualizado</p>
            <h2 id="titulo-ultimos">Últimos temas</h2>
          </div>
          <a class="btn btn-ghost btn-sm" href="/temas/">
            {t.labels.verTodo}
          </a>
        </div>
        <div class="card-grid">
          {ultimos.map((entry, i) => (
            <div class="reveal" style={`--reveal-delay: ${i * 0.08}s`}>
              <ArticleCard entry={entry} showCategory={CATEGORIAS[entry.data.category].name} />
            </div>
          ))}
        </div>
      </section>
    )
  }

  <section class="section container">
    <div class="cta-quiz glass glass-aurora reveal">
      <div>
        <h2>¿Cuánto sabes <span class="text-aurora">de verdad</span>?</h2>
        <p>
          Responde el quiz por categorías: feedback inmediato, explicación en cada pregunta y tu
          mejor marca guardada.
        </p>
      </div>
      <a class="btn btn-primary" href="/quiz/">Empezar un quiz <Icon name="flecha" size={18} /></a>
    </div>
  </section>

  <script>
    // Contador animado de las métricas del hero. Sin JS o con reduced-motion
    // se muestra el número real (ya renderizado en el HTML).
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      const nums = document.querySelectorAll<HTMLElement>('.stat-num[data-count]');
      for (const el of nums) {
        const target = Number(el.dataset.count);
        if (!Number.isFinite(target)) continue;
        const dur = 1100;
        let start: number | undefined;
        el.textContent = '0';
        const tick = (now: number) => {
          if (start === undefined) start = now;
          const p = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = String(Math.round(target * eased));
          if (p < 1) requestAnimationFrame(tick);
          else el.textContent = String(target);
        };
        requestAnimationFrame(tick);
      }
    }
  </script>
</Layout>

<style>
  .hero {
    position: relative;
    padding-block: clamp(4.5rem, 11vw, 7.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  /* La constelación solo aparece donde hay sitio horizontal real */
  .hero-visual {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      align-items: center;
      column-gap: clamp(1.5rem, 4vw, 3.5rem);
    }

    .hero-copy {
      grid-column: 1;
      grid-row: 1;
    }

    .hero-visual {
      display: block;
      grid-column: 2;
      grid-row: 1;
    }

    .stats {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }

  /* Resplandor aurora que flota tras el titular (radiales suaves, sin blur) */
  .hero-glow {
    position: absolute;
    top: clamp(-4rem, -6vw, -2rem);
    left: clamp(-8rem, -12vw, -3rem);
    width: min(48rem, 92%);
    aspect-ratio: 1.5;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(38% 44% at 32% 40%, var(--glow-cyan), transparent 70%),
      radial-gradient(42% 46% at 64% 58%, var(--glow-violet), transparent 72%);
    will-change: transform;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-glow {
      animation: heroGlowDrift 20s ease-in-out infinite alternate;
    }
  }

  @keyframes heroGlowDrift {
    from {
      transform: translate3d(-2%, -1%, 0) scale(1);
    }
    to {
      transform: translate3d(4%, 3%, 0) scale(1.1);
    }
  }

  /* Píldora con punto "en vivo" */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.9rem 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--accent-soft);
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--cyan);
  }

  .hero-badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-badge-dot {
      animation: heroPulse 2.4s ease-out infinite;
    }
  }

  @keyframes heroPulse {
    0% {
      box-shadow: 0 0 0 0 var(--glow-cyan);
    }
    70% {
      box-shadow: 0 0 0 0.5rem transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }

  h1 {
    font-size: var(--text-hero);
    max-width: 16ch;
    margin-top: 1.25rem;
  }

  /* Barrido de brillo sobre el degradado del titular */
  .hero-shimmer {
    background: linear-gradient(
      100deg,
      var(--cyan) 0%,
      var(--violet) 45%,
      var(--cyan) 90%
    );
    background-size: 220% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-shimmer {
      animation: heroShimmer 9s linear infinite;
    }
  }

  @keyframes heroShimmer {
    to {
      background-position: 220% 0;
    }
  }

  .hero-sub {
    margin-top: 1.25rem;
    color: var(--text-muted);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    max-width: 52ch;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  /* La flecha del CTA principal avanza al pasar el ratón */
  .hero-cta .btn-primary :global(svg) {
    transition: transform 0.25s ease;
  }

  @media (hover: hover) {
    .hero-cta .btn-primary:hover :global(svg) {
      transform: translateX(3px);
    }
  }

  /* Franja de métricas */
  .stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 3rem 0 0;
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-lg);
  }

  .stat dd {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.9rem;
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
    transition: transform 0.25s ease;
  }

  @media (hover: hover) {
    .stat:hover .stat-num {
      transform: translateY(-2px) scale(1.04);
    }
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Tarjetas de sección */
  .seccion-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 14px;
    color: var(--cyan);
    background: var(--accent-soft);
    border: 1px solid var(--border);
  }

  .seccion .card-meta {
    color: var(--cyan);
  }

  .head-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    max-width: none;
  }

  .card-grid > .reveal {
    display: grid;
  }

  /* Banda CTA final */
  .cta-quiz {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    padding: clamp(1.75rem, 5vw, 3rem);
    border-radius: var(--radius-lg);
  }

  .cta-quiz h2 {
    font-size: var(--text-h2);
  }

  .cta-quiz p {
    margin-top: 0.75rem;
    color: var(--text-muted);
    max-width: 52ch;
  }

  @media (min-width: 680px) {
    .stats {
      grid-template-columns: repeat(4, 1fr);
    }

    .cta-quiz {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>

---
import Layout from '../../../layouts/Layout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import EmptyState from '../../../components/EmptyState.astro';
import Icon from '../../../components/Icon.astro';
import { CATEGORY_SLUGS, CATEGORIAS } from '../../../lib/categorias';
import { getTemas } from '../../../lib/content';
import { t } from '../../../ui';

export function getStaticPaths() {
  // Las 10 categorías tienen URL estable desde el primer día,
  // aunque todavía no tengan artículos (se muestra un estado vacío).
  return CATEGORY_SLUGS.map((categoria) => ({ params: { categoria } }));
}

const { categoria } = Astro.params;
const cat = CATEGORIAS[categoria];
const temas = await getTemas(cat.slug);
---

<Layout title={cat.name} description={`${cat.description} Temas de ${cat.name} en DevAtlas.`}>
  <div class="container">
    <nav class="crumbs crumbs-top" aria-label="Migas de pan">
      <a href="/temas/">{t.nav.temas}</a>
      <span class="sep" aria-hidden="true">/</span>
      <span aria-current="page">{cat.name}</span>
    </nav>

    <header class="page-head cat-head">
      <span class:list={['cat-icon', `cat-${cat.color}`]}><Icon name={cat.icon} size={26} /></span>
      <div>
        <h1>{cat.name}</h1>
        <p class="page-sub">{cat.description}</p>
        <p class="cat-conteo">{t.labels.temasCount(temas.length)}</p>
      </div>
    </header>

    {
      temas.length > 0 ? (
        <div class="card-grid">
          {temas.map((entry, i) => (
            <div class="reveal" style={`--reveal-delay: ${(i % 3) * 0.07}s`}>
              <ArticleCard entry={entry} />
            </div>
          ))}
        </div>
      ) : (
        <EmptyState
          icon={cat.icon}
          title={t.empty.categoriaSinTemas}
          sub={t.empty.categoriaSinTemasSub}
          ctaHref="/temas/"
          ctaLabel={t.labels.volver}
        />
      )
    }
  </div>
</Layout>

<style>
  .crumbs-top {
    padding-top: 1.5rem;
  }

  .cat-head {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    padding-top: 1.5rem;
  }

  .cat-head h1 {
    margin-top: 0;
  }

  .cat-icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 14px;
    border: 1px solid var(--border);
  }

  .cat-cyan {
    color: var(--cyan);
    background: var(--accent-soft);
  }

  .cat-violet {
    color: var(--violet);
    background: var(--violet-soft);
  }

  .cat-conteo {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    color: var(--cyan);
  }

  .card-grid > .reveal {
    display: grid;
  }
</style>

<script>
  // Revela el chip "Leído" en las tarjetas de temas ya leídos.
  import { getProgreso } from '../../../lib/progress';

  const progreso = getProgreso();
  document.querySelectorAll<HTMLElement>('[data-tema-id]').forEach((card) => {
    if (progreso.temas[card.dataset.temaId ?? '']) {
      card.querySelector<HTMLElement>('[data-estado-leido]')?.removeAttribute('hidden');
    }
  });
</script>

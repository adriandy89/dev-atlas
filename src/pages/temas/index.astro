---
import Layout from '../../layouts/Layout.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { listaCategorias } from '../../lib/categorias';
import { conteosPorCategoria } from '../../lib/content';
import { t } from '../../ui';

const conteos = await conteosPorCategoria();
const totalTemas = Object.values(conteos.temas).reduce((a, b) => a + b, 0);
---

<Layout
  title="Temas"
  description="Base de conocimiento de ingeniería de software: algoritmos, estructuras de datos, patrones de diseño, buenas prácticas, metodologías y más."
>
  <div class="container">
    <header class="page-head">
      <p class="eyebrow">Base de conocimiento</p>
      <h1>Temas</h1>
      <p class="page-sub">
        {totalTemas} artículos organizados en {listaCategorias.length} categorías. Explicaciones
        claras, con código y sin relleno.
      </p>
    </header>

    <div class="card-grid">
      {
        listaCategorias.map((cat, i) => {
          const n = conteos.temas[cat.slug] ?? 0;
          return (
            <div class="reveal" style={`--reveal-delay: ${(i % 3) * 0.07}s`}>
              <CategoryCard
                categoria={cat}
                meta={n > 0 ? t.labels.temasCount(n) : t.empty.proximamente}
                muted={n === 0}
                showProgress={n > 0}
                total={n}
              />
            </div>
          );
        })
      }
    </div>
  </div>
</Layout>

<style>
  .card-grid > .reveal {
    display: grid;
  }
</style>

<script>
  // Pinta la barra de temas leídos por categoría sobre las tarjetas estáticas.
  // Sin progreso (o sin localStorage) las tarjetas quedan igual.
  import { getProgreso } from '../../lib/progress';

  const progreso = getProgreso();
  document.querySelectorAll<HTMLElement>('[data-cat-slug]').forEach((el) => {
    const slug = el.dataset.catSlug ?? '';
    const total = Number(el.dataset.total) || 0;
    if (total === 0) return;
    // Los ids de tema son `categoria/slug`: cuenta por prefijo de categoría.
    const leidos = Object.keys(progreso.temas).filter((id) => id.split('/')[0] === slug).length;
    if (leidos === 0) return;

    const pct = Math.round((leidos / total) * 100);
    el.querySelector('[data-pbar]')?.setAttribute('aria-valuenow', String(pct));
    const fill = el.querySelector<HTMLElement>('[data-pbar-fill]');
    if (fill) fill.style.width = `${pct}%`;
    const conteo = el.querySelector('[data-cat-conteo]');
    if (conteo) conteo.textContent = `${leidos}/${total} leídos`;
    el.hidden = false;
  });
</script>

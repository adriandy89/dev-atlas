# Cabeceras para Cloudflare Workers (assets estáticos).
# Este archivo no se sirve al público: Workers lo interpreta.

# Los archivos de /_astro llevan hash en el nombre (cambian de URL
# en cada build), así que pueden cachearse "para siempre".
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Endurecimiento básico (sin efecto en SEO)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
